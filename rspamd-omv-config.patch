diff -up rspamd-3.14.3/rspamd.service.1~ rspamd-3.14.3/rspamd.service
--- rspamd-3.14.3/rspamd.service.1~	2026-01-08 14:17:41.000000000 +0100
+++ rspamd-3.14.3/rspamd.service	2026-02-21 15:30:57.735805049 +0100
@@ -1,6 +1,8 @@
 [Unit]
 Description=rapid spam filtering system
-After=nss-lookup.target network-online.target
+After=nss-lookup.target network-online.target redis@rspamd-temp.service redis@rspamd-permanent.service
+Requires=redis@rspamd-temp.service redis@rspamd-permanent.service
+PartOf=redis@rspamd-temp.service redis@rspamd-permanent.service
 Documentation=https://rspamd.com/doc/
 
 [Service]
@@ -8,10 +10,46 @@ LimitNOFILE=1048576
 NonBlocking=true
 ExecStart=/usr/bin/rspamd -c /etc/rspamd/rspamd.conf -f
 ExecReload=/bin/kill -HUP $MAINPID
-User=_rspamd
+User=rspamd
+Group=rspamd
+Restart=always
+
+# Filesystem
+ProtectSystem=strict
+ProtectHome=true
+ReadWritePaths=/var/log/rspamd /var/cache/rspamd /srv/rspamd
+PrivateTmp=true
+PrivateDevices=true
 RuntimeDirectory=rspamd
 RuntimeDirectoryMode=0755
-Restart=always
+CacheDirectory=rspamd
+CacheDirectoryMode=0750
+
+# Kernel/system protection
+ProtectKernelTunables=true
+ProtectKernelModules=true
+ProtectKernelLogs=true
+ProtectControlGroups=true
+ProtectClock=true
+ProtectHostname=true
+
+# Privilege escalation
+NoNewPrivileges=true
+RestrictSUIDSGID=true
+
+# Capabilities - runs as unprivileged user on non-privileged port
+CapabilityBoundingSet=
+
+# Network
+RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
+
+# System calls
+SystemCallFilter=@system-service
+SystemCallArchitectures=native
+LockPersonality=true
+RestrictRealtime=true
+RestrictNamespaces=true
+OOMScoreAdjust=-100
 
 [Install]
 WantedBy=multi-user.target
