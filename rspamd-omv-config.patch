+++ rspamd-3.14.3/conf/modules.d/classifier-bayes.conf	2026-02-21 16:47:45.616982893 +0100
@@ -0,0 +1,10 @@
+backend = "redis";
+servers = "/run/redis/rspamd-permanent/redis.sock";
+new_schema = true;
+expire = 8640000;  # 100 days
+min_learns = 200;
+autolearn {
+	spam_threshold = 12.0;
+	ham_threshold = -2.0;
+	check_balance = true;
+}
